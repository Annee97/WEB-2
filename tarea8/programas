<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="../programas/css/style.css">
    <script src="calculadora.js" defer></script>
    <title>Calculadora</title>
</head>
<body>
    <div class="container">
        <h1>Calculadora</h1>
        
        
        <div class="calculator">
            <div class="calculator-display" id="display">0</div>
            <div class="calculator-grid">
             
                <button class="clear span-two" id="clearBtn">C</button>
                <button class="operator" data-operator="/">&divide;</button>
                <button class="operator" data-operator="*">&times;</button>
                
                <button data-number="7">7</button>
                <button data-number="8">8</button>
                <button data-number="9">9</button>
                <button class="operator" data-operator="-">-</button>
                
                <button data-number="4">4</button>
                <button data-number="5">5</button>
                <button data-number="6">6</button>
                <button class="operator" data-operator="+">+</button>
             
                <button data-number="1">1</button>
                <button data-number="2">2</button>
                <button data-number="3">3</button>
                <button class="equals span-two-row" id="equalsBtn">=</button>
                
                <button class="span-two" data-number="0">0</button>
                <button data-number=".">.</button>
            </div>
        </div>
        
      

        <a href="/" class="button-back">Volver al Inicio</a>
    </div>
</body>
</html>
